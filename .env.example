# Copy this file to `.env.local` and fill in the value for local development.
# `.env.local` is gitignored; never commit real keys.
#
# For the deployed site, this same variable is provided as a GitHub Actions
# secret (repo Settings -> Secrets and variables -> Actions) and injected at
# build time by .github/workflows/deploy.yml.
#
# Google Calendar API key (restrict it in Google Cloud to your site's referrer
# and the Calendar API only — it is visible in the shipped browser bundle).
VITE_GCAL_API_KEY=
